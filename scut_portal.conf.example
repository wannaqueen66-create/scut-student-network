# Example configuration for scut_portal_login.sh
# Copy this file to your local machine and adjust the values for your network.
# Do NOT commit real credentials.

# Credentials
PORTAL_USER="your-student-id-or-portal-username"
PORTAL_PASS="your-portal-password"

# Network interface
IFACE="apclix0"

# Portal parameters
# How to get them:
# - AC_NAME: from portal page URL (e.g. wlanacname=...) or login request params
# - HOST: from login request URL hostname
# - PORT: from login request URL port
# - HOST_IP: optional; leave empty unless you need a fixed DNS resolution result
AC_NAME="example_ac"
HOST="portal.example.edu.cn"
HOST_IP=""
PORT="802"

# Logging
LOG="/tmp/scut_portal_login.log"
DEBUG="0"

# Retry behavior
TIMEOUT_CHECK="5"
TIMEOUT_LOGIN="12"
MAX_IP_RETRY="3"
FAIL_RESET_THRESHOLD="2"
LOGIN_ATTEMPTS="3"
RETRY_SLEEP="3"

# Safety: disabled by default because ifdown/ifup is disruptive on some systems
ENABLE_IFACE_RESET="0"
